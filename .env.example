# ══════════════════════════════════════════════════════════════════════════════
# AI Portfolio Architect — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
#
# 1. Copy:    cp .env.example .env
# 2. Fill in all values below.
# 3. Never commit .env — it is in .gitignore.
#
# Rules: no quotes, no spaces around =
# ══════════════════════════════════════════════════════════════════════════════

# ── Nebius Token Factory (LLM) ────────────────────────────────────────────────
# Your API key from https://studio.nebius.ai → API Keys
NEBIUS_KEY=sk-your-key-here

# Model used for generation (criterion extraction, synthesis, evolutionary mutations)
GENERATION_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Per-request timeout (seconds) and retry count for hosted-LLM generation calls.
# Bounds the tail latency of claim extraction so one hung response can't stall a
# build (SDK defaults are 600s / 2 retries).
GENERATION_TIMEOUT_S=75
GENERATION_MAX_RETRIES=1

# Model used for judging — ideally distinct from generation model
JUDGE_MODEL=nvidia/Llama-3_1-Nemotron-Ultra-253B-v1

# ── Nebius AI Endpoints (Embeddings) ─────────────────────────────────────────
# Full URL of your deployed embedding endpoint, e.g.:
# https://<endpoint-id>.api.nebius.ai/v1
# Leave blank to skip embedding (retrieval will degrade to keyword-only)
NEBIUS_EMBEDDING_URL=https://your-endpoint-id.api.nebius.ai/v1

# Embedding model name served by the endpoint above
EMBEDDING_MODEL=BAAI/bge-m3

# Dimension of embeddings produced by the model above.
# BAAI/bge-m3 → 1024. Must match the VECTOR(N) in the DB schema.
# Changing this requires: drop chunks table, recreate, re-embed everything.
EMBEDDING_DIM=1024

# ── SQLite database ──────────────────────────────────────────────────────────
# Path to the SQLite database file (created automatically on first run).
DATABASE_PATH=portfolio_architect.db

# ── Application ──────────────────────────────────────────────────────────────
# API base URL — used by the Streamlit UI to call the FastAPI backend
API_BASE_URL=http://localhost:8000

# Number of chunks to retrieve per workstream query
RETRIEVAL_TOP_K=15

# Number of evolutionary mutation candidates to generate each cycle
EVOLUTIONARY_N_MUTATIONS=3

# Maximum tokens per LLM call (cost safety)
MAX_TOKENS_GENERATION=2048
# 6144: the judge (reasoning) model needs room for a long <think> trace + JSON
# verdict; a tighter cap can truncate the JSON into a "not valid JSON" failed grade.
MAX_TOKENS_JUDGE=6144
